# Firebase Web App (Console → Project settings → Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
# Usa il dominio dell'app (es. card.appspottly.com), NON .firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=card.appspottly.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# URL pubblico dell'app (per link card e CSV provisioning)
NEXT_PUBLIC_APP_URL=https://card.appspottly.com

# Solo per script provisioning (non committare)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
